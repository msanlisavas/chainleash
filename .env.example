# Copy to .env and fill in. docker-compose reads these. .env is gitignored.

# CSPR.cloud access key (node RPC + REST). The public testnet key is the default;
# get your own at https://console.cspr.cloud for production rate limits.
CSPR_CLOUD_KEY=55f79117-fc4d-4d60-9956-65423f39a06a

# Your GovernedVault package hash + owner public key (from scripts/onboard.ps1).
# Defaults point at the live demo vault.
VAULT_PKG=hash-f5600a9fcca977de4d2ba259a02ecc9ec5c2256022080b7824cd97fcf5c96591
OWNER_PUBKEY=011A493f54caDeC630682aA2c64A40d0569b9c3A924876C010cFE27735162654B5

# x402 signal provider: where the agent pays per risk read, and the price.
# Driving your OWN vault? Point all three at YOUR keys or the PAY beat stays demo-bound:
#   X402_PAY_TO          = your owner's ACCOUNT HASH (where the fee lands)
#   X402_PROVIDER_PUBKEY = your owner's PUBLIC KEY hex (the agent verifies payTo against it)
#   X402_EXPECTED_PAYER  = your agent's ACCOUNT HASH (the provider only honors YOUR payments)
# `dotnet run -- account-hash` in spike/ChainLeash.Spike prints both account hashes.
X402_PAY_TO=5bc1cf012c678676ff14c3cd3d2d72ac19d17819d448de4795f7bf1618bfd232
X402_PROVIDER_PUBKEY=011A493f54caDeC630682aA2c64A40d0569b9c3A924876C010cFE27735162654B5
X402_EXPECTED_PAYER=11b5fdcc0b9653c5d67891c675d1548193779b7ff0a9c942c03f7e6752b52aeb
X402_PRICE_MOTES=2500000000

# Interface the published ports bind to. Default is loopback only (local machine);
# set 0.0.0.0 to expose the dashboard/provider on your network.
BIND_ADDR=127.0.0.1
