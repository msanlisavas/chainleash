# CHAINLEASH production env — copy to .env ON THE SERVER (gitignored, never committed).
#   cp .env.prod.example .env   # then fill in real values, chmod 600 .env
#
# These feed docker-compose.prod.yml. The agent's signing key is NOT here — it's a file
# at ./secrets/agent/secret_key.pem (chmod 600). Nothing in this file or that key ever
# goes into GitHub; CI only holds a deploy SSH key + Docker Hub token (in a protected
# `production` environment), not these.

# CSPR.cloud access key — used for REST (validator perception + x402 verification). Use YOUR OWN
# key for production; the public key is daily-rate-limited.
CSPR_CLOUD_KEY=

# Node RPC endpoint (chain reads + tx submit). Default = the public Casper testnet node, which has
# no quota — CSPR.cloud's node RPC is daily-quota limited and the agent's low request volume doesn't
# need it. Point this at your own node or back at CSPR.cloud (https://node.testnet.cspr.cloud/rpc) if
# you prefer. NOTE: nodes that reject a "charset" content-type param are handled; both work.
NODE_RPC_URL=https://node.testnet.casper.network/rpc

# The GovernedVault package hash + owner public key the agent drives.
VAULT_PKG=hash-612b07767d7e8245a8a2d2dfd77e56e34776e7be7ecf81b95429b092a30758e3
OWNER_PUBKEY=011A493f54caDeC630682aA2c64A40d0569b9c3A924876C010cFE27735162654B5

# Loopback host port nginx proxies to (not public). Tick cadence + low-gas warn.
# Validators only change per ~2h era, so the agent polls sparingly: TICK_SECONDS sets the
# decision cadence, VALIDATOR_CACHE_SECONDS caches the (single, filtered) validator read.
AGENT_PORT=8120
TICK_SECONDS=600
VALIDATOR_CACHE_SECONDS=1800
CONFIG_CACHE_SECONDS=1800
LOW_GAS_WARN=50

# CSPR.click appId for in-wallet owner co-sign. Register your own at console.cspr.click;
# 'csprclick-template' is the public demo appId (fine to start).
CSPR_CLICK_APP_ID=csprclick-template

# x402 pay-to-think identities (defaults match the demo vault's identities).
X402_PAY_TO=5bc1cf012c678676ff14c3cd3d2d72ac19d17819d448de4795f7bf1618bfd232
X402_PROVIDER_PUBKEY=011A493f54caDeC630682aA2c64A40d0569b9c3A924876C010cFE27735162654B5
X402_EXPECTED_PAYER=11b5fdcc0b9653c5d67891c675d1548193779b7ff0a9c942c03f7e6752b52aeb
X402_PRICE_MOTES=2500000000
